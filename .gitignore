# build output
dist/
# generated types
.astro/

# Generated book mirror — one-way copy of ../book/ produced by
# tools/sync-book-to-site.sh on every npm run dev / build. The authoring
# source at ../book/ is the only thing worth committing.
src/content/book/

# Audio narration toolchain — venv and build-cache manifest are local
# state, recreated on demand. The MP3s and the public manifest.json
# under public/audio/ ARE committed (committed audio rides along with
# the deploy, no LFS needed at current size).
scripts/audio/.venv/
scripts/audio/.audio-manifest.json

