# Enable the audio narration player. Off by default. Set to "true" only after
# generating audio files via `npm run build:audio` (which requires the Kokoro
# Python toolchain and substantial GPU/CPU time).
# PUBLIC_AUDIO_ENABLED=true

# Google Search Console verification token. Paste the value Google gives you
# under Search Console → Add property → URL prefix → HTML tag method
# (everything between content="..." in the snippet). When set, the layout
# emits <meta name="google-site-verification" content="..."> in <head>.
# PUBLIC_GOOGLE_SITE_VERIFICATION=

# View counter (Upstash Redis). These variables are AUTO-POPULATED by Vercel
# when an Upstash Redis store is linked to the project (Vercel dashboard →
# Project → Storage → Create Database → Upstash, then "Connect Project"). The
# integration injects the KV-style names below; the code reads
# KV_REST_API_URL / KV_REST_API_TOKEN (and falls back to the
# UPSTASH_REDIS_REST_* pair if present). `vercel env pull` syncs them to
# `.env.local` for local development. There is no need to set them by hand on
# Vercel. Locally, leaving them unset is fine — the `/api/views/*` endpoints
# return `{ count: null, error: "kv_unavailable" }` and the UI keeps its `—`
# placeholder. See DEPLOY.md → "View counter — Upstash Redis setup".
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=   # injected but unused by the counter
# KV_URL=                        # TCP connection string, unused by the counter
# REDIS_URL=                     # TCP connection string, unused by the counter
